# Shared runtime defaults
POLYMARKET_ENV=dev
POLYMARKET_DATA_DIR=./var
POLYMARKET_LOG_FILTER=info
POLYMARKET_HEARTBEAT_INTERVAL_SECS=5

# Telegram notifications
POLYMARKET_TELEGRAM_ENABLED=false
POLYMARKET_TELEGRAM_BOT_TOKEN_ENV=POLYMARKET_TELEGRAM_BOT_TOKEN
POLYMARKET_TELEGRAM_CHAT_ID_ENV=POLYMARKET_TELEGRAM_CHAT_ID
POLYMARKET_TELEGRAM_DAILY_REPORT_HOUR=20
POLYMARKET_TELEGRAM_DAILY_REPORT_MINUTE=0
POLYMARKET_TELEGRAM_TIMEZONE=Asia/Shanghai
POLYMARKET_TELEGRAM_ALLOWED_DOMAINS=LIVE,CANARY,SIM

# Node startup
POLYMARKET_NODE_DOMAIN=canary
POLYMARKET_NODE_RUNTIME_MODE=Sim
POLYMARKET_EXECUTION_DEFAULT_FEE_BPS=0

# LLM strategy defaults
POLYMARKET_LLM_PROVIDER=openai
POLYMARKET_LLM_BASE_URL=http://127.0.0.1:8000/v1
POLYMARKET_LLM_API_KEY=replace-me
POLYMARKET_LLM_MODEL_NAME=replace-me
POLYMARKET_LLM_TIER_LITE_PROVIDER=
POLYMARKET_LLM_TIER_LITE_BASE_URL=
POLYMARKET_LLM_TIER_LITE_API_KEY=
POLYMARKET_LLM_TIER_LITE_MODEL_NAME=
POLYMARKET_LLM_TIER_HAIKU_PROVIDER=
POLYMARKET_LLM_TIER_HAIKU_BASE_URL=
POLYMARKET_LLM_TIER_HAIKU_API_KEY=
POLYMARKET_LLM_TIER_HAIKU_MODEL_NAME=
POLYMARKET_LLM_TIER_SONNET_PROVIDER=
POLYMARKET_LLM_TIER_SONNET_BASE_URL=
POLYMARKET_LLM_TIER_SONNET_API_KEY=
POLYMARKET_LLM_TIER_SONNET_MODEL_NAME=
POLYMARKET_LLM_TIER_OPUS_PROVIDER=
POLYMARKET_LLM_TIER_OPUS_BASE_URL=
POLYMARKET_LLM_TIER_OPUS_API_KEY=
POLYMARKET_LLM_TIER_OPUS_MODEL_NAME=
POLYMARKET_LLM_ROUTE_OPPORTUNITY_REVIEW=sonnet
POLYMARKET_LLM_ROUTE_TELEGRAM_SUMMARY=haiku
POLYMARKET_LLM_ROUTE_RESEARCH_ENRICHMENT=sonnet
POLYMARKET_LLM_ROUTE_POST_TRADE_EXPLAINER=haiku
POLYMARKET_LLM_ROUTE_DEEP_RESEARCH_MANUAL=opus
POLYMARKET_SEARCH_ENABLED=false
POLYMARKET_SEARCH_BASE_URL=http://127.0.0.1:8081
POLYMARKET_SEARCH_API_KEY=
POLYMARKET_SEARCH_TIMEOUT_MS=4000
POLYMARKET_SEARCH_MAX_RESULTS=5
POLYMARKET_SEARCH_ALLOWED_DOMAINS=
POLYMARKET_SEARCH_BLOCKED_DOMAINS=

# Ops API startup
POLYMARKET_OPS_BIND_ADDR=127.0.0.1:8080
# Keep this unset for local development. Set to true only when a non-loopback bind is intentional.
# POLYMARKET_OPS_ALLOW_NON_LOOPBACK=false
POLYMARKET_OPS_TARGET_DOMAIN=canary
POLYMARKET_OPS_VISIBLE_DOMAINS=sim,canary

# Pick one auth scheme for local use.
# JSON map form is preferred when multiple operators are needed.
POLYMARKET_OPS_AUTH_TOKENS_JSON={"local-dev":"replace-me"}
# Legacy single token fallback.
POLYMARKET_OPS_AUTH_TOKEN=replace-me

# Real execution credentials are intentionally omitted from this example.
# Provide them through local secret storage only when execution is approved.
